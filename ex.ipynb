   "source": [
    "from math import gcd, pow\n",
    "\n",
    "# 최대 공약수\n",
    "num1 = gcd(12,18) # 모듈명.함수명\n",
    "print(f'gcd(12,18) : {num1}')\n",
    "\n",
    "# 제곱, 제곱근\n",
    "num2 = pow(2,5)\n",
    "num3_1 = sqrt(9) # 사용 불가능\n",
    "print(f'pow(2,5) : {num2}')\n",
    "print(f'sqrt(9) : {num3_1}') # 사용 불가능"
   ]
  }
 ],
